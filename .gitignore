# ============================================
# NexusUnreal — UE 测试工程 .gitignore
# ============================================

# IntelliJ project files
.idea/
*.iml
out/
gen/

# Visual Studio
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# UE 可重新生成的工程文件
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/
Plugins/**/Binaries/

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/

# Compiled source files for the engine to use
Intermediate/
Plugins/**/Intermediate/

# C# / MSBuild intermediate (UBT plugins, e.g. UnLua's UnLuaDefaultParamCollectorUbtPlugin)
Plugins/**/obj/
Plugins/**/bin/

# Cache files for the editor to use
DerivedDataCache/

# Rider 生成的 IDE 插件
Plugins/Developer/RiderLink/

# Python 脚本 / 测试
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
.mypy_cache/

# 编辑器运行时反馈目录
.nexus-feedback/

# OS 生成文件
.DS_Store
Thumbs.db
desktop.ini
